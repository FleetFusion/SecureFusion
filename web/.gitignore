# The repo-root .gitignore ignores package-lock.json globally, but the
# verifier SPA uses `npm ci` in CI and needs the lockfile committed.
!package-lock.json

# Dependencies
/node_modules

# Angular build artefacts
/dist
/tmp
/out-tsc
/bazel-out
/.angular/cache

# IDE
.idea
.vscode/*
!.vscode/extensions.json

# Test coverage
/coverage

# Playwright e2e
/playwright-report
/test-results
/.playwright

# Lighthouse CI
/.lighthouseci

# Misc
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db
